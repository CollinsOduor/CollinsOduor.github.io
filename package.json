{
  "private": true,
  "name": "minimal-blog",
  "description": "Typography driven, feature-rich blogging theme with minimal aesthetics. Includes tags/categories support and extensive features for code blocks such as live preview, line numbers, and line highlighting.",
  "version": "1.4.0",
  "author": "Collins Oduor",
  "license": "0BSD",
  "starter-name": "gatsby-starter-minimal-blog",
  "homepage": "http://CollinsOduor.github.io",
  "scripts": {
    "build": "npx gatsby build",
    "develop": "gatsby develop",
    "develop:cypress": "cross-env CYPRESS_SUPPORT=y yarn develop",
    "build:cypress": "cross-env CYPRESS_SUPPORT=y yarn build",
    "start": "gatsby develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "deploy": "gatsby build --prefix-paths && gh-pages -d public"
  },
  "dependencies": {
    "@lekoarts/gatsby-theme-minimal-blog": "^6.2.6",
    "@lekoarts/gatsby-theme-minimal-blog-core": "^6.2.6",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "autoprefixer": "^10.4.27",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "gatsby": "^5.16.1",
    "gatsby-cli": "^5.16.0",
    "gatsby-omni-font-loader": "^2.0.2",
    "gatsby-plugin-catch-links": "^5.16.0",
    "gatsby-plugin-feed": "^5.16.0",
    "gatsby-plugin-gatsby-cloud": "^5.14.0",
    "gatsby-plugin-google-analytics": "^5.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-netlify": "^5.1.1",
    "gatsby-plugin-offline": "^6.16.0",
    "gatsby-plugin-react-helmet": "^6.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-plugin-theme-ui": "^0.17.4",
    "gatsby-plugin-webpack-bundle-analyser-v2": "^1.1.32",
    "mini-css-extract-plugin": "^2.10.0",
    "postcss": "^8.5.8",
    "postcss-flexbugs-fixes": "^5.0.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0"
  }
}
